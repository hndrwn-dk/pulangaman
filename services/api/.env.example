NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://pulangaman:pulangaman@localhost:5432/pulangaman
REDIS_URL=redis://localhost:6379
# Leave empty in local dev to skip Firebase Admin init (auth middleware uses stub)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
CORS_ORIGIN=*
LOCATION_TTL_SECONDS=900
STALE_LOCATION_SECONDS=120
RATE_LIMIT_PER_MINUTE=100
ZONE_DEBOUNCE_SECONDS=45
ZONE_HYSTERESIS_M=15
LOCATION_RETENTION_DAYS=7
PURGE_INTERVAL_MS=3600000
PANIC_SMS_DELAY_MS=30000
PANIC_ESCALATE_DELAY_MS=60000
SMS_PROVIDER=console
SMS_HTTP_URL=
SMS_HTTP_TOKEN=
KILL_SWITCH_GUARDIAN_NOTIFY=false
KILL_SWITCH_LOCATION_SHARE=false
GOOGLE_MAPS_API_KEY=
COMMUNITY_REPORT_TTL_HOURS=72
ROUTE_AVOID_RADIUS_M=120
USAGE_RETENTION_DAYS=14
KILL_SWITCH_POLICY_ENFORCE=false
